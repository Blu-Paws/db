{
  "name": "@blupaws/connection",
  "version": "1.1.2",
  "description": "Shared BluPaws MySQL connection and data model helpers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "MODEL_CONFLICTS.md"
  ],
  "scripts": {
    "build": "node scripts/generate-view-types.js && tsc && node scripts/copy-json.js",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test test/*.test.js",
    "prepack": "npm run clean && npm run build"
  },
  "author": "Samarth",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.947.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.16.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
